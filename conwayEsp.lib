///////////////////////////////////////////////////////////////////////////////
version="2.0";
category="Finite fields";
info="
LIBRARY:  conway.lib   Calculo de polinomios de Conway sobre cuerpos finitos

AUTHOR:   Miguel, TFG Matematicas

OVERVIEW:
  Implementacion del algoritmo de Heath-Loehr (2004) para calcular el
  polinomio de Conway C_{p,n} sobre F_p, con las ideas de Ruano-Laplagne
  (2007) para Singular.

  Dado un primo p y un grado n = q1^e1 * ... * qs^es, el algoritmo
  reduce el espacio de busqueda de p^n candidatos a exactamente
  g = mcd{ (p^n-1)/(p^{n/qi}-1) } candidatos mediante un MCD de
  polinomios, evitando la busqueda exhaustiva para n compuesto.

  Para n primo (s=1, e=1) se usa busqueda exhaustiva en orden de Parker,
  que termina al primer candidato valido (h = p^n/tau ~ 1).

  Para n potencia de primo (s=1, e>1) se usa el algoritmo de Heath-Loehr
  con r(z) = C_{p,n/q}(z) como polinomio auxiliar.

CASOS DEL ALGORITMO:
  n = 1      ->  menor primitivo de F_p (trivial)
  s >= 2     ->  r(z) = mcd{ C_{p,di}(z^{mi/g}) } es irreducible grado n
  s = 1, e=1 ->  n primo: busqueda exhaustiva Parker con parada inmediata
  s = 1, e>1 ->  n = q^e: r(z) = C_{p,n/q}(z), busqueda entre g raices

OPTIMIZACIONES IMPLEMENTADAS:
  - Termino constante fijo por compatibilidad con C_{p,1} (reduce busqueda /p)
  - Orden de Parker exacto en el bucle exhaustivo (parada al primer valido)
  - Poda lexicografica en iterateCandidates (abortar minpoly si ya es peor)
  - Multiplicacion incremental: beta_{k+1} = beta_k * zeta (evita polyPow)
  - Test de primitividad antes de calcular minpoly (descarte rapido)
  - Ideal precalculado una sola vez por llamada
  - Factorizacion de p^n-1 precalculada y reutilizada en todo el bucle
  - Busqueda de irreducibles: trinomios -> pentanomios -> sistematica

REFERENCIAS:
  [HL04] Heath, Loehr: New algorithms for generating Conway polynomials
         over finite fields. J. Symbolic Comput. 38 (2004), 1003-1024.
  [RL07] Ruano, Laplagne: Conway Polynomials and Singular. Segovia, 2007.
  [Lub]  Frank Luebeck: tablas en
         https://www.math.rwth-aachen.de/~Frank.Luebeck/data/ConwayPol/

PROCEDURES (publicas):
  conwayPoly(n [,known])     Calcula C_{p,n}
  isSmallerConway(f,g,n)     Comparacion en orden de Parker
  isPrimitivePoly(f,n)       Test de primitividad
  isCompatible(fn,fm,n,m)    Test de compatibilidad
  candidatosConway(n)        Cuenta g y phi(p^n-1)/n para C_{p,n}
  mostrarCandidatos(n)       Muestra g y phi(p^n-1)/n por pantalla
  testConway([verb])      Test de verificacion contra Luebeck
";

LIB "polylib.lib";


///////////////////////////////////////////////////////////////////////////////
//
//  SECCION 1: ARITMETICA DE ENTEROS GRANDES
//
//  Operaciones sobre bigint que Singular no tiene de serie:
//  mcd, inverso modular, extraccion de coeficientes, factorizacion.
//
///////////////////////////////////////////////////////////////////////////////

// Algoritmo de Euclides para bigint.
proc mcdBigint(bigint a, bigint b)
"USAGE:   mcdBigint(a,b);  a,b bigint
RETURN:  mcd(a,b)
"
{
    if (a < 0) { a = -a; }
    if (b < 0) { b = -b; }
    bigint t;
    while (b != 0) { t = b; b = a mod b; a = t; }
    return(a);
}

// Inverso modular por el algoritmo extendido de Euclides.
// Precondicion: mcd(a,m) = 1.
proc modInverse(bigint a, bigint m)
"USAGE:   modInverse(a,m);  a,m bigint con mcd(a,m)=1
RETURN:  x tal que a*x = 1 mod m
"
{
    bigint m0 = m; bigint x0 = 0; bigint x1 = 1;
    bigint q; bigint t;
    a = ((a mod m) + m) mod m;
    while (a > 1)
    {
        q = a div m; t = m; m = a mod m; a = t;
        t = x0; x0 = x1 - q * x0; x1 = t;
    }
    return(((x1 mod m0) + m0) mod m0);
}

// Devuelve el coeficiente de x^i en f como entero.
proc coeffAt(poly f, int i)
{
    if (deg(f) < i) { return(0); }
    poly term = coeffs(f, var(1)^i);
    if (term == 0) { return(0); }
    return(int(leadcoef(term)));
}

// Factorizacion por division de prueba para n entero pequenyo.
// Devuelve lista de pares [primo, exponente].
proc factorizeSmall(int n)
{
    list L; int idx = 0; int d = 2; int e;
    while (d * d <= n)
    {
        if (n mod d == 0)
        {
            e = 0;
            while (n mod d == 0) { n = n div d; e = e + 1; }
            idx = idx + 1; L[idx] = list(d, e);
        }
        d = d + 1;
    }
    if (n > 1) { idx = idx + 1; L[idx] = list(n, 1); }
    return(L);
}



// Factorizacion para bigint.
// Para numeros grandes usa la llamada al sistema 'factor' de Linux/Cygwin (instantáneo).
// Devuelve lista de pares [primo, exponente].
proc factorizeBigint(bigint n)
{
    list L; 
    
    // 1. Usar el comando 'factor' del SO y formatearlo a código de Singular
    string cmd = "factor " + string(n) + " | cut -d: -f2 | tr -s ' ' '\\n' | grep -v '^$' | uniq -c | awk '{print \"L[\" NR \"]=list(bigint(\" $2 \"),\" $1 \");\"}' > tmp_fac.txt";
    int dummy = system("sh", cmd);
    
    // 2. Leer el resultado
    string output = read("tmp_fac.txt");
    
    // 3. Si funcionó, lo ejecutamos y devolvemos la lista
    if (size(output) > 0)
    {
        execute(output);
        return(L);
    }
    
    // 4. FALLBACK: Si el comando falla por algún motivo, usamos trial division (lento)
    int idx = 0; bigint d = 2; int e;
    while (d * d <= n)
    {
        if (n mod d == 0)
        {
            e = 0;
            while (n mod d == 0) { n = n div d; e = e + 1; }
            idx = idx + 1; L[idx] = list(d, e);
        }
        d = d + 1;
    }
    if (n > 1) { idx = idx + 1; L[idx] = list(n, 1); }
    return(L);
}

// Extrae la lista de factores primos distintos de M.
// Usado para el test de primitividad y para gthRoot.
static proc primeFactors(bigint M, int p, int n)
{
    list facs = factorizeBigint(M);
    list primes;
    int i;
    for (i = 1; i <= size(facs); i++)
    {
        primes[i] = bigint(facs[i][1]);
    }
    if (size(primes) == 0)
    {
        ERROR("primeFactors: no se pudo factorizar " + string(M));
    }
    return(primes);
}


///////////////////////////////////////////////////////////////////////////////
//
//  SECCION 2: ARITMETICA EN F_p[x]/(f)
//
//  Exponenciacion modular, evaluacion de polinomios y polinomio minimo.
//  La funcion nuclear es fastPow, que recibe el ideal ya precalculado
//  para evitar recalcular std() en cada llamada dentro de un bucle.
//
///////////////////////////////////////////////////////////////////////////////

// Exponenciacion modular base^e mod modp en F_p[x].
// Interfaz publica que precalcula el ideal internamente.
proc polyPow(poly base, bigint e, poly modp)
"USAGE:   polyPow(base, e, modp);
RETURN:  base^e mod modp en F_p[x]
NOTE:    Square-and-multiply con reduccion en cada paso.
"
{
    if (e == 0) { return(poly(1)); }
    ideal I = std(ideal(modp));
    poly r = 1;
    base = reduce(base, I);
    while (e > 0)
    {
        if ((e mod 2) == 1) { r = reduce(r * base, I); }
        e = e div 2;
        if (e > 0) { base = reduce(base * base, I); }
    }
    return(r);
}

// Version interna de polyPow que recibe el ideal ya calculado.
// Usarla dentro de bucles para no recalcular std() en cada iteracion.
static proc fastPow(poly base, bigint e, ideal I)
{
    if (e == 0) { return(poly(1)); }
    poly r = 1;
    base = reduce(base, I);
    while (e > 0)
    {
        if ((e mod 2) == 1) { r = reduce(r * base, I); }
        e = e div 2;
        if (e > 0) { base = reduce(base * base, I); }
    }
    return(r);
}

// Evalua f(alpha) en F_p[x]/(modp) usando fastPow para cada monomio.
proc polyEval(poly f, poly alpha, poly modp)
{
    ideal I = std(ideal(modp));
    poly r = 0;
    int d; number c;
    while (f != 0)
    {
        d = deg(lead(f));
        c = leadcoef(f);
        r = reduce(r + c * fastPow(alpha, bigint(d), I), I);
        f = f - lead(f);
    }
    return(r);
}

// Polinomio minimo de alpha en F_p[x]/(modp) sobre F_p.
// Calcula los conjugados de Frobenius: alpha, alpha^p, alpha^{p^2}, ...
// hasta que vuelva al primero, y expande el producto (x-alpha_i).
proc minPoly(poly alpha, int p, int n, poly modp)
{
    ideal I = std(ideal(modp));

    // Paso 1: calcular los conjugados de Frobenius
    list conj;
    conj[1] = reduce(alpha, I);
    poly curr = conj[1];
    int d = 1; int i;
    for (i = 2; i <= n; i++)
    {
        curr = fastPow(curr, bigint(p), I);
        if (curr == conj[1]) { break; }
        d = d + 1; conj[d] = curr;
    }

    // Paso 2: expandir (x - conj[1])*(x - conj[2])*...*(x - conj[d])
    // usando los coeficientes elementales simetricos de forma incremental
    list C; C[1] = poly(1); C[2] = reduce(-conj[1], I);
    int j; int len; list Cnew;
    for (i = 2; i <= d; i++)
    {
        len = size(C); Cnew = list(); Cnew[1] = C[1];
        for (j = 2; j <= len; j++)
        {
            Cnew[j] = reduce(C[j] - conj[i]*C[j-1], I);
        }
        Cnew[len+1] = reduce(-conj[i]*C[len], I);
        C = Cnew;
    }

    // Paso 3: reconstruir el polinomio desde los coeficientes
    poly result = 0; number c;
    for (i = 1; i <= d+1; i++)
    {
        c = leadcoef(C[i]);
        result = result + c * var(1)^(d-i+1);
    }
    return(result);
}

// Version con poda lexicografica de Parker.
// Construye el minpoly y aborta (devuelve poly(0)) en cuanto detecta
// que el resultado ya seria mayor que 'best' en el orden de Parker.
// Si best == 0 no hay con que comparar y devuelve el minpoly completo.
static proc minPolyPruned(poly beta, int p, int n, poly modp, poly best)
{
    ideal I = std(ideal(modp));

    // Conjugados de Frobenius
    list conj; conj[1] = reduce(beta, I);
    poly curr = conj[1];
    int d = 1; int i;
    for (i = 2; i <= n; i++)
    {
        curr = fastPow(curr, bigint(p), I);
        if (curr == conj[1]) { break; }
        d = d + 1; conj[d] = curr;
    }
    // Si el grado del minpoly no es n, este beta no da un Conway de grado n
    if (d != n) { return(poly(0)); }

    // Expandir el producto incremental
    list C; C[1] = poly(1); C[2] = reduce(-conj[1], I);
    int j; int len; list Cnew;
    for (i = 2; i <= d; i++)
    {
        len = size(C); Cnew = list(); Cnew[1] = C[1];
        for (j = 2; j <= len; j++)
        {
            Cnew[j] = reduce(C[j] - conj[i]*C[j-1], I);
        }
        Cnew[len+1] = reduce(-conj[i]*C[len], I);
        C = Cnew;
    }

    // Reconstruir el polinomio
    poly result = 0; number c;
    for (i = 1; i <= d+1; i++)
    {
        c = leadcoef(C[i]);
        result = result + c * var(1)^(d-i+1);
    }

    // Sin referencia: devolver directamente
    if (best == 0) { return(result); }

    // Poda de Parker: comparar result contra best coeficiente a coeficiente
    // desde i = n-1 hacia 0. El valor efectivo de Parker en posicion i es
    //   (-1)^(n-i) * a_i  mod p  con 0 < 1 < ... < p-1.
    int ai; int bi; poly tf; poly tg;
    for (i = n-1; i >= 0; i = i-1)
    {
        tf = jet(result, i); tg = jet(best, i);
        if (deg(tf) == i) { ai = int(leadcoef(tf)); } else { ai = 0; }
        if (deg(tg) == i) { bi = int(leadcoef(tg)); } else { bi = 0; }
        if ((n-i) mod 2 != 0)
        {
            ai = ((-ai) mod p + p) mod p;
            bi = ((-bi) mod p + p) mod p;
        }
        else
        {
            ai = (ai mod p + p) mod p;
            bi = (bi mod p + p) mod p;
        }
        if (ai > bi) { return(poly(0)); } // peor -> podar
        if (ai < bi) { return(result);  } // mejor -> aceptar
    }
    return(poly(0)); // iguales -> no reemplazar
}


///////////////////////////////////////////////////////////////////////////////
//
//  SECCION 3: ORDEN LEXICOGRAFICO DE PARKER
//
//  El orden de Conway (<lex de Parker) compara los coeficientes de
//  f = x^n + a_{n-1}x^{n-1} + ... + a_1 x + a_0
//  desde a_0 hacia arriba usando el valor efectivo (-1)^(n-i) * a_i mod p
//  con el orden 0 < 1 < ... < p-1 en Z_p.
//
//  Para p=2 coincide con el orden lexicografico normal porque -1 = 1.
//  Para p > 2 los coeficientes en posiciones de exponente impar se comparan
//  con signo negativo, lo que invierte su orden relativo.
//
///////////////////////////////////////////////////////////////////////////////

// Comparacion en orden de Parker: devuelve 1 si f <_Parker g, 0 si no.
proc isSmallerConway(poly f, poly g, int n)
{
    int p = char(basering);
    int i; int ai; int bi; poly tf; poly tg;
    for (i = n-1; i >= 0; i = i-1)
    {
        tf = jet(f, i); tg = jet(g, i);
        if (deg(tf) == i) { ai = int(leadcoef(tf)); } else { ai = 0; }
        if (deg(tg) == i) { bi = int(leadcoef(tg)); } else { bi = 0; }
        if ((n-i) mod 2 != 0) { ai = -ai; bi = -bi; }
        ai = ((ai mod p) + p) mod p;
        bi = ((bi mod p) + p) mod p;
        if (ai < bi) { return(1); }
        if (ai > bi) { return(0); }
    }
    return(0);
}

// Convierte un indice de contador (0..p-1) al coeficiente real a_i
// segun el orden de Parker para la posicion i en un polinomio de grado n.
//
// La idea: queremos que al incrementar el contador de 0 a p-1,
// el valor efectivo Parker (-1)^(n-i) * a_i crezca de 0 a p-1.
//
//   Si (n-i) es par:   valor_Parker = a_i           -> a_i en orden 0,1,...,p-1
//   Si (n-i) es impar: valor_Parker = (-a_i mod p)  -> para que crezca,
//                      a_i debe ir 0, p-1, p-2, ..., 1
static proc parkerCoef(int idx, int i, int n, int p)
{
    if ((n - i) mod 2 == 0)
    {
        return(idx);          // orden directo
    }
    else
    {
        if (idx == 0) { return(0); }
        return(p - idx);      // orden invertido: 0, p-1, p-2, ..., 1
    }
}


///////////////////////////////////////////////////////////////////////////////
//
//  SECCION 4: TEST DE PRIMITIVIDAD Y COMPATIBILIDAD
//  isMersenneExponent: comprueba si n es un primo de mersenne.
//  isPrimitivePoly: comprueba que alpha = var(1) genera GF(p^n)*.
//  isCompatible:   comprueba la condicion de anidamiento C_{p,n} | C_{p,m}(x^{e}).
//
///////////////////////////////////////////////////////////////////////////////

// Función auxiliar que guarda la lista de exponentes
static proc isMersenneExponent(int n)
{
    list mersennes = 2, 3, 5, 7, 13, 17, 19, 31, 61, 89, 107, 127, 521, 607, 1279, 2203, 2281, 3217, 4253, 4423, 9689, 9941, 11213, 19937, 21701, 23209, 44497, 86243, 110503, 132049, 216091, 756839, 859433, 1257787, 1398269, 2976221, 3021377, 6972593, 13466917, 20996011, 24036583, 25964951, 30402457, 32582657, 37156667, 42643801, 43112609, 57885161, 74207281, 77232917, 82589933, 136279841;
    int i;
    for (i = 1; i <= size(mersennes); i++)
    {
        if (n == mersennes[i]) { return(1); }
    }
    return(0);
}


// Test de primitividad: f es primitivo sii alpha^{(p^n-1)/q} != 1
// para todo primo q | p^n-1.
proc isPrimitivePoly(poly f, int n, list #)
"USAGE:   isPrimitivePoly(f, n [, factoresDePnMenos1]);
RETURN:  1 si f es primitivo de grado n sobre F_p, 0 si no.
NOTE:    Pasar la lista de factores primos de p^n-1 evita refactorizar.
EXAMPLE: example isPrimitivePoly; shows an example
"
{
    int p = char(basering);
    // --- ATAJO PARA PRIMOS DE MERSENNE ---
    // Si p=2 y n es un exponente de Mersenne conocido, 
    // sabemos 100% que todo irreducible es primitivo.
    if (p == 2 && isMersenneExponent(n))
    {
        return(1);
    }
    // -------------------------------------

    bigint M = bigint(p)^n - 1;

    list primes;
    if (size(#) > 0) { primes = #[1]; }
    
    // Si no nos pasaron los factores precalculados, tenemos que encontrarlos
    if (size(primes) == 0)
    {
        // Si no es primo, intentamos factorizar por trial division si es pequeño
        if (M < bigint(2)^31)
        {
            list facs = factorizeSmall(int(M));
            int i;
            for (i = 1; i <= size(facs); i++) { primes[i] = bigint(facs[i][1]); }
        }
        else
        {  
            primes = primeFactors(M, p, n);
        }
    }
    
    if (size(primes) == 0) { ERROR("isPrimitivePoly: no se pudo factorizar p^n-1."); }

    // Bucle normal de comprobación de primitividad
    int i;
    bigint e; 
    poly r;
    for (i = 1; i <= size(primes); i++)
    {
        e = M div primes[i];
        r = polyPow(var(1), e, f); 
        if (r == 1) { return(0); }
    }
    return(1);
}

// Test de compatibilidad: fn es compatible con fm sii
// fn(x) | fm(x^{(p^n-1)/(p^m-1)}), comprobado evaluando fm en alpha^e.
proc isCompatible(poly fn, poly fm, int n, int m)
"USAGE:   isCompatible(fn, fm, n, m);  con m | n
RETURN:  1 si C_{p,n} = fn es compatible con C_{p,m} = fm.
NOTE:    Evalua fm(alpha^{(p^n-1)/(p^m-1)}) donde alpha es raiz de fn.
"
{
    int p = char(basering);
    bigint Mn = bigint(p)^n - 1;
    bigint Mm = bigint(p)^m - 1;
    bigint e = Mn div Mm;
    poly alpha_e = polyPow(var(1), e, fn);
    poly val = polyEval(fm, alpha_e, fn);
    return(int(val == 0));
}


///////////////////////////////////////////////////////////////////////////////
//
//  SECCION 5: HERRAMIENTAS DE CAMPO FINITO
//
//  Funciones para trabajar en GF(p^n): encontrar generadores, raices
//  g-esimas, raices de polinomios, e irreducibles auxiliares.
//
///////////////////////////////////////////////////////////////////////////////

// Sustitucion x -> x^k en un polinomio f(x), devuelve f(x^k).
static proc substPow(poly f, bigint k)
{
    poly r = 0; int d; number c;
    while (f != 0)
    {
        d = deg(lead(f)); c = leadcoef(f);
        r = r + c * var(1)^int(bigint(d) * k);
        f = f - lead(f);
    }
    return(r);
}

// Busca un generador de GF(p^n)* = F_p[x]/(modp)* por busqueda sistematica.
// Un elemento gamma genera el grupo sii gamma^{M/q} != 1 para todo primo q|M.
static proc findGenerator(poly modp, int p, int n, bigint M, list primesM)
{
    ideal I = std(ideal(modp));
    poly one = poly(1);
    int c; poly gamma; int is_gen; int j; int rem; int coef_val; int i;
    for (c = 2; c < 2000000; c++)
    {
        // Construir el elemento c en base p como polinomio en F_p[x]
        gamma = 0; rem = c;
        for (i = 0; rem > 0; i++)
        {
            coef_val = rem mod p;
            if (coef_val != 0) { gamma = gamma + number(coef_val) * var(1)^i; }
            rem = rem div p;
        }
        // Test de generador
        is_gen = 1;
        for (j = 1; j <= size(primesM); j++)
        {
            if (fastPow(gamma, M div primesM[j], I) == one) { is_gen = 0; break; }
        }
        if (is_gen) { return(gamma); }
    }
    ERROR("findGenerator: no encontrado en 2000000 intentos para grado " + string(n));
}

// Extrae una raiz g-esima de z0 en GF(p^n).
// Metodo: si mcd(g, M/g) = 1 usamos inversion modular (O(log g)).
// En caso contrario usamos busqueda directa con multiplicacion incremental.
static proc gthRoot(poly z0, bigint g, poly modp, int p, int n)
{
    bigint M = bigint(p)^n - 1;
    bigint ordz = M div g;
    bigint gmod = g mod ordz;
    if (gmod == 0) { gmod = g; }
    bigint mcd_val = mcdBigint(gmod, ordz);
    ideal I = std(ideal(modp));

    // Caso facil: inversion modular directa
    if (mcd_val == 1)
    {
        bigint e = modInverse(gmod, ordz);
        return(fastPow(z0, e, I));
    }

    // Caso general: busqueda entre las M/g potencias de gamma
    list primesM = primeFactors(M, p, n);
    poly gamma = findGenerator(modp, p, n, M, primesM);
    poly step = fastPow(gamma, g, I);
    poly cur = 1;
    poly z0_red = reduce(z0, I);
    bigint j; bigint limit = M div g;
    for (j = 0; j <= limit; j = j + 1)
    {
        if (cur == z0_red) { return(fastPow(gamma, j, I)); }
        cur = reduce(cur * step, I);
    }
    ERROR("gthRoot: raiz no encontrada para g = " + string(g));
}

// Devuelve una raiz g-esima primitiva de la unidad: zeta = gamma^{M/g}.
static proc gthRootOfUnity(bigint g, poly modp, int p, int n, bigint M, list primesM)
{
    if (M mod g != 0) { ERROR("gthRootOfUnity: g no divide p^n-1."); }
    poly gamma = findGenerator(modp, p, n, M, primesM);
    ideal I = std(ideal(modp));
    return(fastPow(gamma, M div g, I));
}

// Busca un polinomio irreducible de grado n sobre F_p.
// Estrategia: primero trinomios x^n + x^i + a0 (los mas comunes),
// luego pentanomios, y finalmente busqueda sistematica como ultimo recurso.
static proc findIrred(int p, int n)
{
    poly candidate; int k; int is_irred; list facs;
    int i; int j; int m; int a0;

    // Intento 1: trinomios x^n + x^i + a0
    for (i = 1; i < n; i++)
    {
        for (m = 1; m < p; m++)
        {
            candidate = var(1)^n + var(1)^i + number(m);
            is_irred = isIrreducibleBenOr(candidate, n);
            if (is_irred && deg(candidate) == n) { return(candidate); }
        }
    }

    // Intento 2: pentanomios x^n + x^i + x^j + x^m + a0
    for (i = n-1; i > 2; i = i-1)
    {
        for (j = i-1; j > 1; j = j-1)
        {
            for (m = j-1; m > 0; m = m-1)
            {
                for (a0 = 1; a0 < p; a0++)
                {
                    candidate = var(1)^n + var(1)^i + var(1)^j + var(1)^m + number(a0);
                    is_irred = isIrreducibleBenOr(candidate, n);
                    if (is_irred && deg(candidate) == n) { return(candidate); }
                }
            }
        }
    }

    // Intento 3: busqueda sistematica (lento para n y p grandes)
    int max_val = p^(n-1); int c; int coef_val; int rem;
    for (c = 1; c < max_val; c++)
    {
        if ((c mod p) == 0) { continue; } // termino independiente cero -> reducible
        candidate = var(1)^n; rem = c;
        for (i = 0; i < n; i++)
        {
            coef_val = rem mod p;
            if (coef_val != 0) { candidate = candidate + number(coef_val) * var(1)^i; }
            rem = rem div p;
        }
        is_irred = isIrreducibleBenOr(candidate, n);
        if (is_irred && deg(candidate) == n) { return(candidate); }
    }
    ERROR("findIrred: no encontrado para p=" + string(p) + ", n=" + string(n));
}

// Busca una raiz de f(x) en GF(p^n) = F_p[x]/(modp)
// probando las potencias gamma^{step}, gamma^{2*step}, ...
// donde step = (p^n-1)/(p^d-1) hace que solo visitemos el subgrupo
// correcto de orden p^d-1.
static proc findRoot(poly f, poly modp, int p, int n)
{
    int d = deg(f);
    bigint Mn = bigint(p)^n - 1;
    bigint Md = bigint(p)^d - 1;
    list primesM = primeFactors(Mn, p, n);
    poly gamma = findGenerator(modp, p, n, Mn, primesM);
    bigint step = Mn div Md;
    ideal I = std(ideal(modp));
    poly gamma_step = fastPow(gamma, step, I);
    poly cur = 1; poly val; bigint j;
    for (j = 0; j < Md; j = j + 1)
    {
        val = polyEval(f, cur, modp);
        if (val == 0) { return(cur); }
        cur = reduce(cur * gamma_step, I);
    }
    ERROR("findRoot: raiz de " + string(f) + " no encontrada en GF(" + string(p) + "^" + string(n) + ")");
}


///////////////////////////////////////////////////////////////////////////////
//
//  SECCION 6: NUCLEO DEL ALGORITMO HEATH-LOEHR
//
//  Tres casos segun la factorizacion de n:
//    caseComposite    -> s >= 2 primos distintos
//    casePrimePower   -> s = 1, n = q^e con e >= 2
//    casePrimeExhaust -> s = 1, e = 1, n primo
//
//  En todos los casos se llama finalmente a iterateCandidates, que
//  recorre las g raices g-esimas de z0 y devuelve el menor minpoly
//  primitivo en orden de Parker.
//
///////////////////////////////////////////////////////////////////////////////

// Caso n = q1^e1 * ... * qs^es con s >= 2.
//
// El teorema 9 de Heath-Loehr garantiza que el polinomio
//   r(z) = mcd{ C_{p,di}(z^{mi/g}) }
// es irreducible de grado n. Tomamos z0 = var(1) (raiz de r) y buscamos
// entre las g raices g-esimas de z0 el menor primitivo.
//
// Caso compuesto (s >= 2 primos distintos)
static proc caseComposite(int n, int p, int s, list di, list qi,
                           list mi, list Cpdi, bigint g)
{
    // --- NUEVO: Abortar temprano si g es inmanejable ---
    if (g > bigint(20000000))
    {
        "//   g INMANEJABLE (" + string(g) + ") -> Abortando Heath-Loehr. Loteria Parker...";
        return(exhaustiveSearch(n, p, Cpdi, di));
    }
    // ---------------------------------------------------

    // Identificar el indice del divisor di con menor grado de sustitucion
    bigint minDeg = bigint(di[1]) * (mi[1] div g);
    int minIdx = 1; int i;
    for (i = 2; i <= s; i++)
    {
        bigint deg_i = bigint(di[i]) * (mi[i] div g);
        if (deg_i < minDeg) { minDeg = deg_i; minIdx = i; }
    }
    "//   [COMPUESTO] Grado del polinomio menor en MCD: " + string(minDeg);
    poly rz;
    if (s == 2 && minDeg < 50000)
    {
        "//   Factorizando polinomio menor (grado " + string(minDeg) + ")...";
        poly small_poly = substPow(Cpdi[minIdx], mi[minIdx] div g);
        list facs = factorize(small_poly);
        int otherIdx = 3 - minIdx;
        int k; poly factor_k; poly z0_pow; poly val;
        rz = 0;
        for (k = 1; k <= size(facs[1]); k++)
        {
            if (deg(facs[1][k]) == n)
            {
                factor_k = facs[1][k];
                z0_pow = polyPow(var(1), mi[otherIdx] div g, factor_k);
                val = polyEval(Cpdi[otherIdx], z0_pow, factor_k);
                if (val == 0) { rz = factor_k; break; }
            }
        }
        if (rz == 0) { ERROR("caseComposite: no se encontro factor compatible."); }
    }
    else
    {
        "//   Calculando MCD de polinomios de sustitucion...";
        poly G = substPow(Cpdi[1], mi[1] div g);
        for (i = 2; i <= s; i++)
        {
            poly Hi = substPow(Cpdi[i], mi[i] div g);
            G = gcd(G, Hi);
        }
        rz = G;
    }

    "//   r(z) obtenido, grado " + string(deg(rz));
    return(selectBest(rz, p, n, g));
}

// Caso n = potencia de primo (s = 1, e >= 2)
static proc casePrimePower(int n, int p, int q1, int ndivq,
                            poly Cpndivq, bigint g)
{
    "//   [POTENCIA DE PRIMO] n = " + string(q1) + "^" + string(factorizeSmall(n)[1][2]);
    "//   Candidatos g = " + string(g);

    if (g <= bigint(20000000))
    {
        "//   g es manejable -> metodo de raices g-esimas";
        poly irr = findIrred(p, n);
        poly z0 = findRoot(Cpndivq, irr, p, n);
        return(selectBestWithIrr(z0, irr, p, n, g));
    }

    "//   g INMANEJABLE -> Abortando Heath-Loehr. Loteria Parker...";
    // Se pasa como lista para unificar con el caso compuesto
    return(exhaustiveSearch(n, p, list(Cpndivq), list(ndivq)));
}

// --- Búsqueda exhaustiva en orden de Parker (Lotería Unificada) ---
// Ahora acepta una lista de divisores y comprueba compatibilidad con TODOS.
static proc exhaustiveSearch(int n, int p, list Cpdi, list di)
{
    "//   [EXHAUSTIVA] Busqueda en orden Parker para p=" + string(p)
        + ", n=" + string(n);

    // --- Termino constante fijado por compatibilidad con C_{p,1} ---
    int a0_int;
    if (p == 2)
    {
        a0_int = 1;
    }
    else
    {
        poly cp1 = conwayDeg1(p);
        int a0_C1 = int(leadcoef(jet(cp1, 0)));
        int gamma_val = ((-a0_C1) mod p + p) mod p;
        if (n mod 2 == 0) { a0_int = gamma_val mod p; }
        else              { a0_int = ((-gamma_val) mod p + p) mod p; }
    }
    "//   Termino constante fijado: a_0 = " + string(a0_int);

    // --- Factores de p^n - 1 para el test de primitividad ---
    bigint M = bigint(p)^n - 1;
    list primesM;
    int M_is_prime = 0;
    if (p == 2 && isMersenneExponent(n)) { M_is_prime = 1; }
    {
        "//   p^n - 1 es primo -> todo irreducible es primitivo";
        primesM[1] = M;
    }
    else
    {
        primesM = primeFactors(M, p, n);
        "//   " + string(size(primesM)) + " factores primos de p^n-1";
    }

    // --- Exponentes de compatibilidad (precalculados una sola vez) ---
    int s = size(di);
    list compat_exp;
    int m_idx;
    for (m_idx = 1; m_idx <= s; m_idx++)
    {
        compat_exp[m_idx] = M div (bigint(p)^di[m_idx] - 1);
    }

    // --- Contadores Parker: cnt[i] in {0,...,p-1} para a_i, i=1..n-1 ---
    // cnt[1] corresponde a a_1 (varia mas rapido en Parker tras a_0).
    int i; list cnt;
    for (i = 1; i <= n-1; i = i+1) { cnt[i] = 0; }

    poly candidate;
    int coef_val; int is_irred; int k; list facs; int done = 0;
    int total = 0;
    poly alpha_e; poly val; int is_comp; int is_prim; int j;
    bigint e; poly r;

    while (!done)
    {
        total = total + 1;

        // --- Construir candidato con coeficientes Parker ---
        candidate = var(1)^n + number(a0_int);
        for (i = 1; i <= n-1; i = i+1)
        {
            coef_val = parkerCoef(cnt[i], i, n, p);
            if (coef_val != 0)
            {
                candidate = candidate + number(coef_val) * var(1)^i;
            }
        }

        // --- Test 1: irreducibilidad ---
        is_irred = isIrreducibleBenOr(candidate, n);

        if (is_irred && deg(candidate) == n)
        {
            // --- Test 2: compatibilidad con TODOS los divisores maximales ---
            is_comp = 1;
            for (m_idx = 1; m_idx <= s; m_idx++)
            {
                alpha_e = polyPow(var(1), compat_exp[m_idx], candidate);
                val = polyEval(Cpdi[m_idx], alpha_e, candidate);
                if (val != 0) { is_comp = 0; break; }
            }

            if (is_comp)
            {
                // --- Test 3: primitividad ---
                is_prim = 1;
                if (!M_is_prime)
                {
                    for (j = 1; j <= size(primesM); j++)
                    {
                        e = M div primesM[j];
                        r = polyPow(var(1), e, candidate);
                        if (r == 1) { is_prim = 0; break; }
                    }
                }
                if (is_prim)
                {
                    "//   Conway encontrado tras " + string(total)
                        + " candidatos: " + string(candidate);
                    return(candidate);
                }
            }
        }

        // --- Avanzar al siguiente candidato en orden Parker ---
        // Incrementar cnt[1], propagando acarreo hacia cnt[2], cnt[3], ...
        i = 1;
        while (i <= n-1)
        {
            cnt[i] = cnt[i] + 1;
            if (cnt[i] < p) { break; }
            cnt[i] = 0; i = i + 1;
        }
        if (i > n-1) { done = 1; }

        // Progreso
        if (total mod 5000 == 0)
        {
            "//   Probados " + string(total) + " candidatos...";
        }
    }
    ERROR("exhaustiveSearch: espacio agotado para p="
        + string(p) + ", n=" + string(n));
}



// Para n primo, g = (p^n-1)/(p-1) es enorme pero h = p^n/tau ~ 1,
// lo que significa que el Conway aparece muy pronto en la lista
// lexicografica de Parker. Por eso iteramos en orden de Parker exacto
// y paramos al primer candidato valido.
//
// El termino constante a_0 = (-1)^n * gamma (donde gamma es la raiz
// de C_{p,1}) esta fijado de antemano por la condicion de compatibilidad,
// lo que reduce el espacio de busqueda en un factor p.

static proc casePrimeExhaust(int n, int p, poly C1)
{
    "//   [PRIMO] Busqueda exhaustiva en orden Parker para n=" + string(n);

    // Calcular el termino constante obligatorio por compatibilidad con C_{p,1}:
    // Si alpha es raiz de C_{p,n} entonces alpha^{(p^n-1)/(p-1)} = gamma
    // donde gamma es la raiz de C_{p,1}. El producto de las raices de C_{p,n}
    // es (-1)^n * gamma, que es exactamente el termino independiente.
    int a0_C1 = int(leadcoef(jet(C1, 0)));
    int gamma_val = ((-a0_C1) mod p + p) mod p;
    int const_term;
    if (n mod 2 == 0) { const_term = gamma_val mod p; }
    else              { const_term = ((-gamma_val) mod p + p) mod p; }
    "//   Termino constante fijado: a_0 = " + string(const_term);

    // Precalcular factores de p^n-1 una sola vez para todo el bucle
    bigint M = bigint(p)^n - 1;
    list primesM;

    // --- ATAJO PARA PRIMOS DE MERSENNE EN EL BUCLE EXHAUSTIVO ---
    if (p == 2 && isMersenneExponent(n))
    {
        primesM[1] = M; // Si es Mersenne, el único factor primo es él mismo
    }
    else
    {
        primesM = primeFactors(M, p, n);
    }

    // Contadores Parker: cnt[i] in {0,...,p-1} para la posicion a_i, i=1..n-1.
    // cnt[1] varia mas rapido (comparado primero por Parker tras a_0).
    int i; list cnt;
    for (i = 1; i <= n-1; i = i+1) { cnt[i] = 0; }

    poly candidate;
    int coef_val; int is_irred; int k; list facs; int done = 0;
    
    int debug_contador = 0; // NUEVO CONTADOR

    while (!done)
    {
        debug_contador = debug_contador + 1;
        if (debug_contador mod 100 == 0) 
        { 
            "// Buscando... probados " + string(debug_contador) + " candidatos de Parker."; 
        }

        // Construir candidato con coeficientes en orden de Parker
        candidate = var(1)^n + number(const_term);
        // Construir candidato con coeficientes en orden de Parker
        candidate = var(1)^n + number(const_term);
        for (i = 1; i <= n-1; i = i+1)
        {
            coef_val = parkerCoef(cnt[i], i, n, p);
            if (coef_val != 0) { candidate = candidate + number(coef_val) * var(1)^i; }
        }

        // Test 1: irreducibilidad (test de Ben-Or)
        is_irred = isIrreducibleBenOr(candidate, n);

        if (is_irred)
        {
            // Test 2: primitividad (usa primesM precalculado)
            if (isPrimitivePoly(candidate, n, list(primesM)))
            {
                // Test 3: compatibilidad con C_{p,1}
                if (isCompatible(candidate, C1, n, 1))
                {
                    // PARADA INMEDIATA: el primero valido en orden Parker es el Conway
                    "//   Conway encontrado: " + string(candidate);
                    return(candidate);
                }
            }
        }

        // Avanzar al siguiente candidato en orden Parker:
        // incrementar cnt[1], propagando el acarreo hacia cnt[2], cnt[3], ...
        i = 1;
        while (i <= n-1)
        {
            cnt[i] = cnt[i] + 1;
            if (cnt[i] < p) { break; }
            cnt[i] = 0; i = i + 1;
        }
        if (i > n-1) { done = 1; }
    }
    ERROR("casePrimeExhaust: no encontrado para n=" + string(n) + ", p=" + string(p));
}


///////////////////////////////////////////////////////////////////////////////
//
//  SECCION 7: SELECCION DEL MEJOR CANDIDATO
//
//  Una vez obtenida la raiz z0 del polinomio auxiliar r(z), hay exactamente
//  g raices g-esimas de z0 en GF(p^n), dadas por alpha * zeta^k para
//  k = 0, ..., g-1, donde alpha es una raiz g-esima de z0 y zeta es una
//  raiz g-esima primitiva de la unidad.
//
//  iterateCandidates recorre estas g raices con las optimizaciones:
//    1. Test de primitividad antes de calcular el minpoly.
//    2. Multiplicacion incremental beta_{k+1} = beta_k * zeta.
//    3. Poda lexicografica de Parker en el calculo del minpoly.
//
///////////////////////////////////////////////////////////////////////////////

// Punto de entrada para caseComposite: z0 = var(1) en GF(p^n) = F_p[z]/(modp).
static proc selectBest(poly modp, int p, int n, bigint g)
{
    bigint M = bigint(p)^n - 1;
    list primesM = primeFactors(M, p, n);
    "//   Calculando raiz g-esima de z0...";
    poly alpha = gthRoot(var(1), g, modp, p, n);
    poly zeta  = gthRootOfUnity(g, modp, p, n, M, primesM);
    "//   Iterando " + string(g) + " candidatos con poda Parker...";
    return(iterateCandidates(alpha, zeta, modp, p, n, g, M, primesM));
}

// Punto de entrada para casePrimePower: z0 es una raiz de r(z) ya calculada.
static proc selectBestWithIrr(poly z0, poly modp, int p, int n, bigint g)
{
    bigint M = bigint(p)^n - 1;
    list primesM = primeFactors(M, p, n);
    "//   Calculando raiz g-esima de z0...";
    poly alpha = gthRoot(z0, g, modp, p, n);
    poly zeta  = gthRootOfUnity(g, modp, p, n, M, primesM);
    "//   Iterando " + string(g) + " candidatos con poda Parker...";
    return(iterateCandidates(alpha, zeta, modp, p, n, g, M, primesM));
}

// Bucle principal sobre los g candidatos.
// Para cada beta = alpha * zeta^k:
//   - descarta los no primitivos rapidamente
//   - calcula el minpoly con poda Parker
//   - actualiza 'best' si el nuevo minpoly es mejor
static proc iterateCandidates(poly alpha, poly zeta, poly modp,
                               int p, int n, bigint g, bigint M,
                               list primesM)
{
    ideal I = std(ideal(modp));
    poly best = 0; int found = 0;
    bigint k; bigint count_prim = 0;
    poly beta = reduce(alpha, I);
    int is_prim; int j; poly one = poly(1); poly mp;

    for (k = 0; k < g; k = k+1)
    {
        // Test de primitividad: beta^{M/q} != 1 para todo primo q | M
        is_prim = 1;
        for (j = 1; j <= size(primesM); j++)
        {
            if (fastPow(beta, M div primesM[j], I) == one) { is_prim = 0; break; }
        }

        if (is_prim)
        {
            count_prim = count_prim + 1;
            // Calcular minpoly con poda lexicografica de Parker
            mp = minPolyPruned(beta, p, n, modp, best);
            if (mp != 0)
            {
                best = mp; found = 1;
                "//   Nuevo mejor en k=" + string(k) + ": " + string(best);
            }
        }

        // Multiplicacion incremental: evita recalcular beta desde alpha cada vez
        beta = reduce(beta * zeta, I);

        // Progreso cada 5000 iteraciones
        if (k > 0 && (k mod 5000 == 0))
        {
            "//   Progreso: k=" + string(k) + "/" + string(g)
                + "  primitivos=" + string(count_prim);
        }
    }

    if (!found) { ERROR("iterateCandidates: ningun candidato primitivo encontrado."); }
    "//   Completado: " + string(count_prim) + " primitivos de " + string(g) + " candidatos.";
    return(best);
}


///////////////////////////////////////////////////////////////////////////////
//
//  SECCION 8: ENTRADA PRINCIPAL Y RECURSION
//
///////////////////////////////////////////////////////////////////////////////


// Calcula el polinomio de Conway C_{p,n} donde p = char(basering).
// Se puede pasar una lista 'known' con Conway ya calculados para reutilizar.
proc conwayPoly(int n, list #)
"USAGE:   conwayPoly(n [, known]);
RETURN:  poly, el polinomio de Conway C_{p,n}
ASSUME:  ring R = p, x, dp; con p primo.
EXAMPLE: example conwayPoly; shows an example
"
{
    int p = char(basering);
    if (p == 0) { ERROR("char(basering) debe ser primo > 0."); }

    list known;
    if (size(#) > 0) { known = #[1]; }

    poly result = conwayRec(n, p, known);
    return(result);
}
example
{
    "EXAMPLE:"; echo = 2;
    ring R = 2, x, dp;
    conwayPoly(1);
    conwayPoly(3);
    conwayPoly(6);
}

// Recursion interna. Calcula C_{p,n} recursivamente sobre los divisores de n.
static proc conwayRec(int n, int p, list known)
{
    
    // 1. Caché en memoria RAM (lista known)
    if (size(known) >= n)
    {
        if (typeof(known[n]) == "poly")
        {
            if (known[n] != 0) 
            { 
                "// [RAM] Rescatado C_{" + string(p) + "," + string(n) + "} de la memoria rapida!";
                return(known[n]); 
            }
        }
    }

    // 2. Caso base
    if (n == 1)
    {
        poly c1 = conwayDeg1(p);
        return(c1);
    }

    // 3. Factorizar n
    list facN = factorizeSmall(n);
    int s = size(facN);
    list di; list qi;
    int i;
    for (i = 1; i <= s; i++)
    {
        qi[i] = facN[i][1];
        di[i] = n div qi[i];
    }

    // 4. Calcular recursivamente los Conway de divisores maximales
    list Cpdi;
    int sz;
    for (i = 1; i <= s; i++)
    {
        Cpdi[i] = conwayRec(di[i], p, known);
        sz = size(known);
        if (sz < di[i])
        {
            int kk;
            for (kk = sz + 1; kk <= di[i]; kk++) { known[kk] = poly(0); }
        }
        known[di[i]] = Cpdi[i];
    }

    // 5. Parámetros
    list mi;
    for (i = 1; i <= s; i++)
    {
        mi[i] = (bigint(p)^n - 1) div (bigint(p)^di[i] - 1);
    }
    bigint g = mi[1];
    for (i = 2; i <= s; i++) { g = mcdBigint(g, mi[i]); }

    "// ============================================";
    "// C_{" + string(p) + "," + string(n) + "}: s=" + string(s)
        + ", g=" + string(g);
    "// ============================================";

    // 6. Delegar al caso
    poly result;
    if (s >= 2)
    {
        // Caso compuesto (varios primos distintos)
        result = caseComposite(n, p, s, di, qi, mi, Cpdi, g);
    }
    else
    {
        if (facN[1][2] == 1)
        {
            // Caso primo puro (exponente = 1). Va directo a busqueda de Parker.
            result = casePrimeExhaust(n, p, Cpdi[1]);
        }
        else
        {
            // Caso potencia de primo (exponente >= 2). Va a Heath-Loehr o Loteria.
            result = casePrimePower(n, p, qi[1], di[1], Cpdi[1], g);
        }
    }

    return(result);
}

// C_{p,1}: menor elemento primitivo de F_p, expresado como x - gamma.
// Los casos frecuentes estan hardcodeados para evitar el bucle.
static proc conwayDeg1(int p)
{
    if (p == 2)  { return(var(1) + 1); }
    if (p == 3)  { return(var(1) + 1); }  // gamma=2, x-2 = x+1 en F_3
    if (p == 5)  { return(var(1) + 3); }  // gamma=2, x-2 = x+3 en F_5
    if (p == 7)  { return(var(1) + 4); }  // gamma=3, x-3 = x+4 en F_7
    if (p == 11) { return(var(1) + 9); }  // gamma=2, x-2 = x+9 en F_11
    if (p == 13) { return(var(1) + 11); } // gamma=2, x-2 = x+11 en F_13

    // Para otros primos: buscar el menor primitivo por fuerza bruta
    list fp1 = factorizeSmall(p - 1);
    int g;
    for (g = 2; g < p; g++)
    {
        int ok = 1;
        int j;
        for (j = 1; j <= size(fp1); j++)
        {
            bigint e = bigint(p-1) div bigint(fp1[j][1]);
            bigint r = 1; bigint base = bigint(g); bigint ee = e;
            while (ee > 0)
            {
                if ((ee mod 2) == 1) { r = (r * base) mod bigint(p); }
                ee = ee div 2;
                if (ee > 0) { base = (base * base) mod bigint(p); }
            }
            if (r == 1) { ok = 0; break; }
        }
        if (ok) { return(var(1) - number(g)); }
    }
    ERROR("conwayDeg1: no se encontro primitivo en F_" + string(p));
}

// Calcula C_{2,n} para todos los exponentes de Mersenne.
// Para estos n, 2^n - 1 es primo, asi que todo irreducible de grado n
// con termino constante 1 que sea el menor en Parker es el Conway.
// No necesita factorizar 2^n-1 ni test de primitividad.
//
// REQUIERE: ring R = 2, x, dp;
proc conwayPolyMersenne()
"USAGE:   conwayPolyMersenne();
RETURN:  nada (imprime resultados por pantalla)
ASSUME:  ring R = 2, x, dp;
NOTE:    Calcula C_{2,n} para todos los exponentes de Mersenne conocidos,
         deteniendose cuando el calculo se vuelve inviable.
         Para estos n, 2^n-1 es primo, todo irreducible es primitivo,
         y el Conway es el menor irreducible monico con a_0=1 en Parker.
"
{
    if (char(basering) != 2) { ERROR("Se requiere caracteristica 2."); }

    list mersennes = 2, 3, 5, 7, 13, 17, 19, 31, 61, 89, 107, 127,
                     521, 607, 1279, 2203, 2281, 3217, 4253, 4423,
                     9689, 9941, 11213, 19937, 21701, 23209, 44497,
                     86243, 110503, 132049, 216091, 756839, 859433,
                     1257787, 1398269, 2976221, 3021377, 6972593,
                     13466917, 20996011, 24036583, 25964951, 30402457,
                     32582657, 37156667, 42643801, 43112609, 57885161,
                     74207281, 77232917, 82589933, 136279841;

    "";
    "==========================================================";
    "  Polinomios de Conway para exponentes de Mersenne (p=2)";
    "  2^n - 1 primo => todo irreducible es primitivo";
    "  Solo hay que buscar el menor irreducible con a_0 = 1";
    "==========================================================";
    "";

    int n, t, elapsed, i;
    poly result;
    for (i = 1; i <= size(mersennes); i++)
    {
        n = mersennes[i];
        "// --- C_{2," + string(n) + "} (Mersenne M_" + string(n) + ") ---";

        t = timer;
        result = menorIrredParker(n);
        elapsed = timer - t;

        if (result != 0)
        {
            "//   C_{2," + string(n) + "} = " + string(result);
            "//   Tiempo: " + string(elapsed) + " ms";
            "";
        }
        else
        {
            "//   No se pudo calcular (grado demasiado grande).";
            "//   Deteniendo aqui.";
            return();
        }
    }
}

// Busca el menor polinomio irreducible monico de grado n sobre F_2
// con termino constante 1, en orden de Parker.
// En caracteristica 2, Parker = lexicografico estandar.
//
// Estrategia: recorrer polinomios x^n + a_{n-1}x^{n-1} + ... + a_1*x + 1
// en orden lexicografico (a_1 varia mas rapido) y devolver el primero
// que sea irreducible.
//
// Optimizacion: test de irreducibilidad de Ben-Or.
// Para F_2 y n primo basta comprobar x^{2^n} = x mod f(x),
// evitando factorizar el polinomio.
static proc menorIrredParker(int n)
{
    // Caso trivial
    if (n == 2) { return(var(1)^2 + var(1) + 1); }
    if (n == 3) { return(var(1)^3 + var(1) + 1); }

    // Para grados muy grandes, avisamos y paramos
    // (el test de irreducibilidad se vuelve muy lento)
    if (n > 50000)
    {
        "//   AVISO: grado " + string(n) + " demasiado grande para"
            + " test de irreducibilidad en tiempo razonable.";
        return(poly(0));
    }

    // Contadores Parker: cnt[i] para a_i, i = 1..n-1
    // En char 2, Parker = lex estandar, asi que cnt[1] varia mas rapido.
    // Todos los coeficientes son 0 o 1 (estamos en F_2).
    list cnt;
    int i;
    for (i = 1; i <= n-1; i++) { cnt[i] = 0; }

    int total = 0;
    int done = 0;
    poly candidate;

    while (!done)
    {
        total = total + 1;

        // Construir candidato: x^n + sum(cnt[i]*x^i) + 1
        candidate = var(1)^n + 1;
        for (i = 1; i <= n-1; i++)
        {
            if (cnt[i] != 0) { candidate = candidate + var(1)^i; }
        }

        // Test de irreducibilidad.
        // Para F_2 y n primo: f es irreducible de grado n
        // sii x^{2^n} = x mod f. Esto evita factorize().
        if (isIrredBen(candidate, n))
        {
            "//   Encontrado tras " + string(total) + " candidatos";
            return(candidate);
        }

        // Avanzar al siguiente en orden Parker (= lex para p=2)
        i = 1;
        while (i <= n-1)
        {
            cnt[i] = cnt[i] + 1;
            if (cnt[i] < 2) { break; }
            cnt[i] = 0;
            i = i + 1;
        }
        if (i > n-1) { done = 1; }

        if (total mod 1000 == 0)
        {
            "//   Probados " + string(total) + " candidatos...";
        }
    }

    return(poly(0));
}

// Test de irreducibilidad de Ben-Or (1981).
//
// Un polinomio f de grado n sobre F_p es irreducible sii:
//   (1) x^{p^n} = x mod f
//   (2) gcd(x^{p^d} - x, f) = 1 para todo 1 <= d <= n/2
//
// La condicion (1) verifica que las raices de f estan en F_{p^n}.
// La condicion (2) verifica que ninguna raiz esta en un subcuerpo.
//
// Para n primo, (2) se reduce a gcd(x^p - x, f) = 1, que es
// trivialmente cierto si f tiene grado > 1 y termino constante != 0.
// Asi que para n primo basta con (1).
//
// Para n compuesto, hay que comprobar (2) para cada d que divida a n
// con d < n. En la practica, basta con los d = n/q para cada primo q | n.
//
// Coste: O(n^2 * log(p^n)) operaciones en F_p, frente al O(n^3) o peor
// de los algoritmos de factorizacion completa.
static proc isIrreducibleBenOr(poly f, int n)
{
    int p = char(basering);
    ideal I = std(ideal(f));

    // Condicion (1): x^{p^n} = x mod f
    // Calculamos x^{p^n} haciendo n veces x -> x^p mod f
    poly cur = var(1);
    int i;
    for (i = 1; i <= n; i++)
    {
        cur = fastPow(cur, bigint(p), I);
    }
    if (cur != var(1)) { return(0); }

    // Condicion (2): gcd(x^{p^d} - x, f) = 1 para d | n, d < n
    // Solo necesitamos comprobar d = n/q para cada primo q | n.
    list facN = factorizeSmall(n);
    int j,d,k;
    poly xpd, h, g;
    for (j = 1; j <= size(facN); j++)
    {
        d = n div facN[j][1];
        if (d < n)
        {
            // Calcular x^{p^d} mod f haciendo d cuadrados/potencias
            xpd = var(1);
            for (k = 1; k <= d; k++)
            {
                xpd = fastPow(xpd, bigint(p), I);
            }
            // gcd(x^{p^d} - x, f) debe ser 1
            h = xpd - var(1);
            if (h == 0) { return(0); }
            g = gcd(h, f);
            if (deg(g) > 0) { return(0); }  // factor comun no trivial
        }
    }

    return(1);
}




///////////////////////////////////////////////////////////////////////////////
//
//  SECCION 9: CONTEO DE CANDIDATOS
//
//  candidatosConway calcula g y phi(p^n-1)/n para cualquier (p,n),
//  sin limite de precision porque usa bigint en Singular.
//
///////////////////////////////////////////////////////////////////////////////

// Calcula g (candidatos compatibles) y phi(p^n-1)/n (irreducibles primitivos)
// para el polinomio de Conway C_{p,n}.
proc candidatosConway(int n)
"USAGE:   candidatosConway(n);  n entero positivo
RETURN:  list(g, phi(p^n-1)/n)
ASSUME:  ring R = p, x, dp; con p primo.
NOTE:    g = mcd{ (p^n-1)/(p^{n/qi}-1) } segun Heath-Loehr.
         phi(p^n-1)/n = numero de polinomios irreducibles primitivos de grado n.
"
{
    int p = char(basering);
    bigint Mn = bigint(p)^n - 1;

    // Calcular g
    bigint g;
    if (n == 1)
    {
        g = 1;
    }
    else
    {
        list facN = factorizeSmall(n);
        int s = size(facN); int i;
        list mi;
        for (i = 1; i <= s; i++)
        {
            int qi = facN[i][1];
            mi[i] = Mn div (bigint(p)^(n div qi) - 1);
        }
        g = mi[1];
        for (i = 2; i <= s; i++) { g = mcdBigint(g, mi[i]); }
    }

    // Calcular phi(Mn) = Mn * prod_{q primo, q|Mn} (1 - 1/q)
    // usando phi(Mn) = prod q^(e-1)*(q-1) para cada q^e || Mn
    list facs_raw = primeFactors(Mn, p, n);
    bigint phi_Mn = Mn;
    int j;
    for (j = 1; j <= size(facs_raw); j++)
    {
        bigint q = facs_raw[j];
        phi_Mn = phi_Mn div q * (q - 1);
    }

    bigint irred_prim = phi_Mn div bigint(n);

    list result;
    result[1] = g;
    result[2] = irred_prim;
    return(result);
}

// Muestra por pantalla el resumen de candidatos para C_{p,n}.
proc mostrarCandidatos(int n)
"USAGE:   mostrarCandidatos(n);  n entero positivo
ASSUME:  ring R = p, x, dp; con p primo.
"
{
    int p = char(basering);
    list res = candidatosConway(n);
    bigint g        = res[1];
    bigint phi_n    = res[2];
    "";
    "=== Candidatos para C_{" + string(p) + "," + string(n) + "} ===";
    "  g   (candidatos compatibles con Conway de grado inferior): " + string(g);
    "  phi(p^n-1)/n  (irreducibles primitivos de grado n totales): " + string(phi_n);
    "  El Conway C_{p,n} es el menor en orden Parker entre los g compatibles.";
    "";
}
